      <pubDate>Mon, 22 Jan 2024 01:01:01 +0900</pubDate>
      <guid>https://murkouc.github.io/2024/01/%E3%82%B7%E3%83%B3%E3%83%97%E3%83%AB%E3%81%AAqa%E3%82%B7%E3%82%B9%E3%83%86%E3%83%A0%E3%82%92%E4%BD%9C%E3%82%8B/</guid>
      <description>&lt;h6 id=&#34;基本環境&#34;&gt;[基本環境]&lt;/h6&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;Google Cloud Platform (GCP)&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h6 id=&#34;やりたいこと&#34;&gt;[やりたいこと]&lt;/h6&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;Vertex AI Searchを基礎にシンプルなQAシステムを作る&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h6 id=&#34;cloud-storageの設定&#34;&gt;[Cloud Storageの設定]&lt;/h6&gt;&#xA;&lt;p&gt;目的：QAシステムからの回答の情報源となるデータを準備する&lt;/p&gt;</description>
